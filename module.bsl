&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Начальные настройки интерфейса
	ВидСравненияДаты = 0; // Равно
	ТипЭкстремума     = 0; // Минимум
	
	// Реализация динамического условия №2: Пол кандидата - Мужской
	// Условное оформление создается программно
	НастроитьУсловноеОформлениеПрограммно();
	
КонецПроцедуры

&НаСервере
Процедура НастроитьУсловноеОформлениеПрограммно()
	
	ЭлементОформления = УсловноеОформление.Элементы.Добавить();
	
	// Цвет светло-зеленый (204, 255, 204)
	ЭлементОформления.Оформление.УстановитьЗначениеПараметра("ЦветФона", Новый Цвет(204, 255, 204));
	
	// Условие: Нужна скрытая колонка в ТЗ или вычисляемое поле. 
	// Для простоты добавим в ТЗ невидимую колонку "СтатусАкцептован" (Булево)
	ЭлементУсловия = ЭлементОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементУсловия.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("СписокВедомостей.СтатусАкцептован");
	ЭлементУсловия.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
	ЭлементУсловия.ПравоеЗначение = Истина;
	
	// Поле оформления
	ПолеОформления = ЭлементОформления.Поля.Элементы.Добавить();
	ПолеОформления.Поле = Новый ПолеКомпоновкиДанных("СписокВедомостей");
	
КонецПроцедуры

// --- КОМАНДА: ЗАПОЛНИТЬ НУЖНОЕ ---

&НаКлиенте
Процедура ЗаполнитьНужное(Команда)
	ЗаполнитьНужноеНаСервере();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьНужноеНаСервере()
	
	СписокВедомостей.Очистить();
	
	ТекущаяДатаСеанса = ТекущаяДатаСеанса();
	ДеньМесяца = День(ТекущаяДатаСеанса);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВедомостьДоговоры.Ссылка КАК Ведомость,
	|	ВедомостьДоговоры.Договор.НачалоДействия КАК ДатаДоговора,
	|	ВедомостьДоговоры.Договор.Активен КАК Активен,
	|	ВедомостьДоговоры.НомерСтроки КАК НомерСтроки,
	|	ВедомостьДоговоры.Ссылка.Дата КАК ДатаДокумента
	|ПОМЕСТИТЬ ВТ_Данные
	|ИЗ
	|	Документ.Ведомость.Договоры КАК ВедомостьДоговоры
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Данные.Ведомость КАК Ведомость,
	|	ВТ_Данные.ДатаДокумента КАК ДатаДокумента,
	|	МИНИМУМ(ВТ_Данные.ДатаДоговора) КАК МинДата,
	|	МАКСИМУМ(ВТ_Данные.ДатаДоговора) КАК МаксДата
	|ПОМЕСТИТЬ ВТ_Экстремумы
	|ИЗ
	|	ВТ_Данные КАК ВТ_Данные
	|ГРУППИРОВАТЬ ПО
	|	ВТ_Данные.Ведомость,
	|	ВТ_Данные.ДатаДокумента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Данные.Ведомость КАК Ведомость,
	|	ВТ_Данные.ДатаДоговора КАК ДатаПервогоАктивного
	|ПОМЕСТИТЬ ВТ_ПервыеАктивные
	|ИЗ
	|	ВТ_Данные КАК ВТ_Данные
	|ГДЕ
	|	ВТ_Данные.Активен = ИСТИНА
	|	И ВТ_Данные.НомерСтроки В
	|			(ВЫБРАТЬ
	|				МИНИМУМ(Т.НомерСтроки)
	|			ИЗ
	|				ВТ_Данные КАК Т
	|			ГДЕ
	|				Т.Ведомость = ВТ_Данные.Ведомость
	|				И Т.Активен = ИСТИНА)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Экстремумы.Ведомость КАК Ведомость,
	|	ВТ_Экстремумы.ДатаДокумента КАК ДатаДокумента
	|ИЗ
	|	ВТ_Экстремумы КАК ВТ_Экстремумы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ПервыеАктивные КАК ВТ_ПервыеАктивные
	|		ПО ВТ_Экстремумы.Ведомость = ВТ_ПервыеАктивные.Ведомость
	|ГДЕ
	|	ВЫБОР
	|		КОГДА &ТипЭкстремума = 0 ТОГДА
	|			ВЫБОР КОГДА &ВидСравнения = 0 ТОГДА ВТ_ПервыеАктивные.ДатаПервогоАктивного = ВТ_Экстремумы.МинДата
	|				  ИНАЧЕ ВТ_ПервыеАктивные.ДатаПервогоАктивного <> ВТ_Экстремумы.МинДата КОНЕЦ
	|		ИНАЧЕ
	|			ВЫБОР КОГДА &ВидСравнения = 0 ТОГДА ВТ_ПервыеАктивные.ДатаПервогоАктивного = ВТ_Экстремумы.МаксДата
	|				  ИНАЧЕ ВТ_ПервыеАктивные.ДатаПервогоАктивного <> ВТ_Экстремумы.МаксДата КОНЕЦ
	|	КОНЕЦ
	|УПОРЯДОЧИТЬ ПО
	|	ДатаДокумента";
	
	Запрос.УстановитьПараметр("ВидСравнения", ВидСравненияДаты);
	Запрос.УстановитьПараметр("ТипЭкстремума", ТипЭкстремума);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	// Фильтрация по динамическому условию №1 (Дата отправки решения)
	// Т.к. условие зависит от ТЕКУЩЕЙ даты в момент выполнения, делаем это в коде
	Индекс = РезультатЗапроса.Количество() - 1;
	Пока Индекс >= 0 Цикл
		СтрокаДанных = РезультатЗапроса[Индекс];
		ДатаДок = СтрокаДанных.ДатаДокумента;
		
		НужноИсключить = Ложь;
		Если ДеньМесяца <= 10 Тогда
			// 1-10 число: Если число даты ведомости равно числу текущей даты
			НужноИсключить = (День(ДатаДок) = ДеньМесяца);
		ИначеЕсли ДеньМесяца <= 20 Тогда
			// 11-20 число: Если число даты ведомости является чётным
			НужноИсключить = (День(ДатаДок) % 2 = 0);
		Иначе
			// 21-31 число: Если месяц даты ведомости является нечётным
			НужноИсключить = (Месяц(ДатаДок) % 2 <> 0);
		КонецЕсли;
		
		Если НужноИсключить Тогда
			РезультатЗапроса.Удалить(СтрокаДанных);
		КонецЕсли;
		Индекс = Индекс - 1;
	КонецЦикла;
	
	// Заполняем таблицу на форме и проверяем статусы для раскраски
	Для Каждого Стр Из РезультатЗапроса Цикл
		НоваяСтрока = СписокВедомостей.Добавить();
		НоваяСтрока.Ведомость = Стр.Ведомость;
		НоваяСтрока.СтатусАкцептован = ПроверитьПоследнийСтатусАкцептован(Стр.Ведомость);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ПроверитьПоследнийСтатусАкцептован(ДокументСсылка)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ИсторияСтатусов.Статус КАК Статус
	|ИЗ
	|	РегистрСведений.ИсторияСтатусовДокументов КАК ИсторияСтатусов
	|ГДЕ
	|	ИсторияСтатусов.Документ = &Документ
	|УПОРЯДОЧИТЬ ПО
	|	ИсторияСтатусов.ДатаЗаписи УБЫВ";
	
	Запрос.УстановитьПараметр("Документ", ДокументСсылка);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Статус = Перечисления.СтатусыДокументов.Акцептован;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункция

// --- КОМАНДА: УДАЛИТЬ ЛИШНЕЕ ---

&НаКлиенте
Процедура УдалитьЛишнее(Команда)
	УдалитьЛишнееНаСервере();
КонецПроцедуры

&НаСервере
Процедура УдалитьЛишнееНаСервере()
	
	МассивДляУдаления = Новый Массив;
	УдаленныеНомера = Новый СписокЗначений;
	
	// 1. Собираем данные для анализа количества договоров
	Для Каждого СтрокаТЗ Из СписокВедомостей Цикл
		
		КоличествоДоговоров = СтрокаТЗ.Ведомость.Договоры.Количество();
		
		Если КоличествоДоговоров > 0 И КоличествоДоговоров % 2 = 0 Тогда
			МассивДляУдаления.Добавить(СтрокаТЗ);
			УдаленныеНомера.Добавить(СтрокаТЗ.Ведомость.Номер);
		КонецЕсли;
		
	КонецЦикла;
	
	// 2. Удаляем строки
	Для Каждого Стр Из МассивДляУдаления Цикл
		СписокВедомостей.Удалить(Стр);
	КонецЦикла;
	
	// 3. Вывод информации (Динамическое условие №3: Фамилия "Иванов" - 6 букв)
	// Реализуем через СообщениеПользователю
	УдаленныеНомера.СортироватьПоЗначению(НаправлениеСортировки.Возр);
	
	ТекстНомеров = "";
	Для Каждого Элемент Из УдаленныеНомера Цикл
		ТекстНомеров = ТекстНомеров + ?(ПустаяСтрока(ТекстНомеров), "", ", ") + Элемент.Значение;
	КонецЦикла;
	
	ШаблонСообщения = "Удалено документов: %1 (%2).";
	ИтоговыйТекст = СтрШаблон(ШаблонСообщения, УдаленныеНомера.Количество(), ТекстНомеров);
	
	ВывестиИнформациюПользователю(ИтоговыйТекст);
	
КонецПроцедуры

&НаСервере
Процедура ВывестиИнформациюПользователю(Текст)
	
	// Динамическое условие №3: Длина фамилии кандидата.
	// Допустим, фамилия "Иванов" (6 знаков). Используем СообщениеПользователю.
	
	Сообщение = Новый СообщениеПользователю;
	Сообщение.Текст = Текст;
	Сообщение.Сообщить();
	
КонецПроцедуры